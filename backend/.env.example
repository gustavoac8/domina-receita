# Database
DATABASE_URL="postgresql://domina:domina@localhost:5432/domina_receita?schema=public"

# App
PORT=4000
NODE_ENV=development
PUBLIC_BASE_URL="http://localhost:4000"

# JWT
JWT_SECRET="troque-este-segredo-em-producao-por-favor"
JWT_EXPIRES_IN="7d"

# IA (opcional; se não setado, usa mock determinístico)
AI_PROVIDER="mock"         # mock | anthropic | openai
AI_API_KEY=""
AI_MODEL="claude-3-5-sonnet-latest"

# ---- Integrações externas ----
# Todos os adapters rodam em modo "stub" se não houver credenciais.
# Basta preencher para ativar modo real.

# Meta / Facebook Ads + Leadgen Webhook
META_ACCESS_TOKEN=""
META_AD_ACCOUNT_ID=""                  # ex: act_1234567890
META_PAGE_ID=""
META_WEBHOOK_VERIFY_TOKEN="troque-me"
META_APP_SECRET=""                     # para validar assinatura do webhook

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""
GOOGLE_ADS_CUSTOMER_ID=""
GOOGLE_ADS_REFRESH_TOKEN=""

# Google My Business (reviews)
GOOGLE_GMB_ACCESS_TOKEN=""
GOOGLE_GMB_LOCATION_ID=""

# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN="troque-me"

# Scheduler
FOLLOWUPS_TICK_SECONDS=60              # intervalo do worker de follow-ups
