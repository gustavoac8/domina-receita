generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth / Tenants ----------
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(DOCTOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinics Clinic[]
}

enum Role {
  SUPER_ADMIN
  STAFF
  ADMIN
  DOCTOR
  OPERATOR
}

// Comercial: leads do SaaS (médicos interessados em assinar)
model MarketingLead {
  id             String   @id @default(cuid())
  name           String
  email          String?
  phone          String?
  specialty      String?
  city           String?
  state          String?
  source         String   @default("organic")
  utm            Json?
  stage          MarketingLeadStage @default(NEW)
  estimatedValue Int?
  notes          String?  @db.Text
  assignedTo     String?
  lastContactAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([stage])
  @@index([source])
}

enum MarketingLeadStage {
  NEW
  QUALIFIED
  DEMO_SCHEDULED
  TRIAL
  WON
  LOST
}

// Audit log: toda acao de super admin ou staff e registrada
model AuditLog {
  id         String   @id @default(cuid())
  actorEmail String
  action     String
  targetType String?
  targetId   String?
  meta       Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorEmail])
  @@index([action])
  @@index([createdAt])
}

model Clinic {
  id         String   @id @default(cuid())
  name       String
  specialty  String
  city       String
  district   String?
  state      String?
  phone      String?
  instagram  String?
  website    String?
  googlePlaceId String?
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  diagnoses       Diagnosis[]
  briefings       Briefing[]
  sites           Site[]
  leads           Lead[]
  campaigns       Campaign[]
  followupJobs    FollowupJob[]
  appointments    Appointment[]
  reviews         Review[]
  referrals       Referral[]
  returnReminders ReturnReminder[]
  seoArticles     SeoArticle[]
  actionPlans     ActionPlan[]
  integrations    Integration[]
}

// ---------- Módulo 1 ----------
model Diagnosis {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  specialty  String
  city       String
  district   String?
  score      Int
  competitors Json
  weaknesses  Json
  attackPlan  Json
  summary     String  @db.Text
  createdAt   DateTime @default(now())
}

// ---------- Módulo 2a ----------
model Briefing {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor     Json
  services   Json
  differentials Json
  media      Json
  tone       Json
  goals      Json
  audience   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sites      Site[]
}

// ---------- Módulo 2b ----------
model Site {
  id         String   @id @default(cuid())
  briefingId String
  briefing   Briefing @relation(fields: [briefingId], references: [id], onDelete: Cascade)
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  slug       String   @unique
  html       String   @db.Text
  status     SiteStatus @default(DRAFT)
  publishedUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum SiteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ---------- Módulo 4: Plano de 90 dias ----------
model ActionPlan {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  title      String
  weeks      Json     // array semana a semana
  budgetSuggested Decimal @db.Decimal(12, 2)
  kpis       Json
  createdAt  DateTime @default(now())
}

// ---------- Módulo 3: CRM ----------
model Lead {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name       String
  phone      String
  email      String?
  source     String?
  procedure  String?
  value      Decimal? @db.Decimal(12, 2)
  stage      LeadStage @default(NEW)
  tags       String[]
  notes      String?  @db.Text
  referralCode String?  // código que trouxe esse lead
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  activities   LeadActivity[]
  followupJobs FollowupJob[]
  appointments Appointment[]
  returnReminders ReturnReminder[]
}

enum LeadStage {
  NEW
  QUALIFIED
  SCHEDULED
  ATTENDED
  RECURRING
  LOST
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  kind      String
  payload   Json
  createdAt DateTime @default(now())
}

// ---------- Módulo 4: Campanhas ----------
model Campaign {
  id          String   @id @default(cuid())
  clinicId    String
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  name        String
  channel     AdChannel
  objective   String
  dailyBudget Decimal  @db.Decimal(12, 2)
  copy        Json
  targeting   Json
  status      CampaignStatus @default(DRAFT)
  spent       Decimal  @default(0) @db.Decimal(12, 2)
  leadsCount  Int      @default(0)
  revenue     Decimal  @default(0) @db.Decimal(12, 2)
  externalId  String?  // id retornado pela plataforma (Meta/Google)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum AdChannel {
  META
  GOOGLE
  TIKTOK
  YOUTUBE
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  FINISHED
}

// ---------- Módulo 8: Follow-ups ----------
model FollowupTemplate {
  id         String   @id @default(cuid())
  code       String   @unique      // "D0", "D2", "D5", "D10", "POS_CONSULTA", "RETORNO_6M"
  name       String
  channel    FollowupChannel
  subject    String?
  body       String   @db.Text
  delayDays  Int      @default(0)  // quando disparar após evento-gatilho
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum FollowupChannel {
  WHATSAPP
  EMAIL
  SMS
}

model FollowupJob {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  templateCode String
  channel    FollowupChannel
  scheduledFor DateTime
  status     FollowupStatus @default(PENDING)
  sentAt     DateTime?
  error      String?
  createdAt  DateTime @default(now())

  @@index([status, scheduledFor])
}

enum FollowupStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

// ---------- Módulo 9: Agendamento / Vendas ----------
model Appointment {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  leadId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id])
  name       String
  phone      String
  procedure  String?
  scheduledFor DateTime
  status     AppointmentStatus @default(SCHEDULED)
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  ATTENDED
  NO_SHOW
  CANCELED
}

// ---------- Módulo 12: Reputação / Avaliações ----------
model Review {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  source     String   // "google" | "instagram" | "internal"
  authorName String
  rating     Int      // 1-5
  comment    String?  @db.Text
  reply      String?  @db.Text
  replyDraft String?  @db.Text
  postedAt   DateTime?
  repliedAt  DateTime?
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ---------- Módulo 13: Pós-vendas / Retornos ----------
model ReturnReminder {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  leadId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  intervalMonths Int   @default(6)
  message    String   @db.Text
  nextDueAt  DateTime
  status     ReturnStatus @default(PENDING)
  createdAt  DateTime @default(now())

  @@index([status, nextDueAt])
}

enum ReturnStatus {
  PENDING
  CONTACTED
  BOOKED
  DISMISSED
}

// ---------- Módulo 14: Indicações ----------
model Referral {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  code       String   @unique
  referrerName String
  referrerPhone String?
  rewardType String   @default("CREDIT") // CREDIT | DISCOUNT | SERVICE
  rewardValue Decimal  @default(100) @db.Decimal(12, 2)
  usedCount  Int      @default(0)
  rewardsPaid Decimal @default(0) @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
}

// ---------- Módulo 5: SEO ----------
model SeoArticle {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  title      String
  slug       String
  keyword    String
  html       String   @db.Text
  status     String   @default("DRAFT")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([clinicId, slug])
}

// ---------- Integrações ----------
model Integration {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  provider   String   // "meta" | "google_ads" | "google_business" | "whatsapp"
  accessToken String? @db.Text
  refreshToken String? @db.Text
  expiresAt  DateTime?
  meta       Json?    // dados adicionais (accountId, pageId, etc)
  status     String   @default("CONNECTED")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([clinicId, provider])
}

model WebhookEvent {
  id         String   @id @default(cuid())
  provider   String
  kind       String
  payload    Json
  processed  Boolean  @default(false)
  createdAt  DateTime @default(now())
}
